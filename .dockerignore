# Language-specific ignores (Java)
*.class
*.jar
*.war
*.ear
# Maven/Gradle (do not include .mvnw, .gradlew, .mvn, .gradle)
target/
# Build outputs
out/
dist/
build/
# IDE and editor files
.idea/
.vscode/
*.iml
*.swp
*.swo
# Version control
.git/
.gitignore
.svn/
.hg/
# Environment and secrets
.env*
*.env
*.pem
*.key
*.crt
config.local.*
*.local.yml
# Documentation
README*
*.md
docs/
# Docker files
Dockerfile*
docker-compose*
# Temporary and local files
tmp/
temp/
*.tmp
.local/
local/
# OS-specific files
.DS_Store
Thumbs.db
# Project-specific static files
web/.DS_Store
web/media/.DS_Store
# Node.js, Python, Go (for completeness)
node_modules/
npm-debug.log
yarn-debug.log
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
/vendor/
*.test
.go-cache/
# Test files
test/
tests/
*_test.go
# Debug files
debug/
*.log
